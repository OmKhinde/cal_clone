{
  "name": "cal-clone-backend-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:backend": "npm run dev -w backend",
    "build": "next build",
    "build:backend": "npm run build -w backend",
    "start": "next start",
    "start:backend": "npm run start -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "npm run typecheck -w backend"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "next": "^15.5.15",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
